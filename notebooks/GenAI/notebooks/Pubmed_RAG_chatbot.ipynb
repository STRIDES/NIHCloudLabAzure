   "source": [
    "### Run the pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "07f20ba9-808c-4795-9f30-15c6c2208d63",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "\n",
    "# 1) PubMed → PMCIDs\n",
    "# Limiting query in Pubmed with Max 600 articles only\n",
    "\n",
    "pmids  = esearch_pubmed(\"breast cancer[Title/Abstract] AND 2026:3000[dp]\", retmax=600) \n",
    "print('PMIDs found:', len(pmids))\n",
    "pmcids = pmid_to_pmcids(pmids)\n",
    "print('PMCIDs mapped:', len(pmcids))\n",
    "\n",
    "# 2) Build chunks (single-stage, with safe caps)\n",
    "# Limiting corpus to be only 100 PubMed articles due to time constraint\n",
    "\n",
    "corpus = build_chunks(pmcids, limit=100)\n",
    "print(\"Chunks:\", len(corpus))\n",
    "\n",
    "# 3) Build FAISS\n",
    "faiss_store = build_faiss(corpus)\n",
    "\n",
    "# 4) Ask a question\n",
    "test_question = \"What are the common warning signs of breast cancer?\"\n",
    "\n",
    "print(\"--- 🚀 RUNNING ZERO-SHOT PROMPTING ---\")\n",
    "zero_shot_response = answer_zero_shot(faiss_store, test_question, k=6)\n",
    "print(zero_shot_response)\n",
    "\n",
    "print(\"\\n--- 🚀 RUNNING ONE-SHOT PROMPTING ---\")\n",
    "one_shot_response = answer_one_shot(faiss_store, test_question, k=6)\n",
    "print(one_shot_response)\n",
    "\n",
    "print(\"\\n--- 🚀 RUNNING FEW-SHOT PROMPTING ---\")\n",
    "few_shot_response = answer_few_shot(faiss_store, test_question, k=6)\n",
    "print(few_shot_response)\n"
   ]
